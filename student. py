class Student:
    def __init__(self, name, age, grade):
        self.name = name
        self.age = age
        self.grade = grade
    def introduce(self):
        print(f"Hello, my name is {self.name}")
    def study(self, subject):
        print(f"I am studying {subject}")

    def is_passed(self):
        if self.grade >= 50:
            print("Student passed")
        else:
            print("Student failed")
s1 = Student("Bassant", 19, 85)
s1.introduce()
s1.study("English")
s1.is_passed()
print("-" * 25)
